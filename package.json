{
  "name": "ticker-tactix-discord-support-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone Discord support ticket bot for Ticker Tactix.",
  "scripts": {
    "start": "node src/index.js",
    "deploy:commands": "node src/deploy-commands.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "node src/db/migrations.js",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=22"
  }
}
